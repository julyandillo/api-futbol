<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#27544B">

    <title>{% block title %}{{ '{app_name}'|trans }}{% endblock %}</title>

    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('img/favicon/apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('img/favicon/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('img/favicon/favicon-16x16.png') }}">
    <link rel="manifest" href="{{ asset('img/favicon/site.webmanifest') }}">

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body>
{% block body %}
{% block menu %}
    <div id="menu">
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_admin_usuarios') }}" class="opcion-menu">
                <span class="icono-menu"><i class="bi bi-people"></i></span>
                <span class="desktop">{{ 'Users'|trans([], 'menu') }}</span>
            </a>
            <a href="{{ path('competiciones') }}" class="opcion-menu">
                <span class="icono-menu"><i class="bi bi-newspaper"></i></span>
                <span class="desktop">{{ 'Competitions'|trans([], 'menu') }}</span>
            </a>
        {% endif %}
        <a href="{{ path('app_logout') }}" class="opcion-menu">
            <span class="icono-menu"><i class="bi bi-door-open"></i></span>
            <span class="desktop">{{ 'Logout'|trans([], 'menu') }}</span>
        </a>
    </div>
{% endblock %}

<div class="contenido">
    {% block contenido %}
    {% endblock %}
</div>

<dialog id="modal-eliminar">
    <div class="modal-content">
        <div class="modal-header"></div>
        <div class="modal-body">
            <p class="modal-msg"></p>
        </div>
        <div class="modal-footer">
            <span class="boton boton-warning modal-btn-ok">Sí</span>
            <span class="boton boton-primary modal-btn-cerrar">No</span>
        </div>
    </div>
</dialog>
<dialog id="modal-editar">
    <div class="modal-content">
        <div class="modal-header"></div>
        <div class="modal-body">
            <div>
                <label for="input__modal-editar"></label>
                <input type="text" name="nombre" id="input__modal-editar">
            </div>
        </div>
        <div class="modal-footer">
            <span class="boton boton-primary modal-btn-ok">Guardar</span>
            <span class="boton boton-secundary modal-btn-cerrar">Cancelar</span>
        </div>
    </div>
</dialog>
</body>
{% endblock %}
</html>
