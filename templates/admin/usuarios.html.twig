{% extends 'admin/index.html.twig' %}

{% trans_default_domain 'admin' %}

{% block javascripts %}
    {{ importmap(['app', 'admin']) }}
{% endblock %}

{% block contenido %}
    <h2>{{ 'Users'|trans }}</h2>
    <table class="tabla-usuarios mt-2">
        <thead>
        <tr>
            <th>{{ 'user'|trans }}</th>
            <th>email</th>
            <th>{{ 'apps'|trans }}</th>
            <th>{{ 'creation date'|trans }}</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
            {% for usuario in usuarios %}
                <tr>
                    <td>{{ usuario.usuario }}</td>
                    <td>{{ usuario.email }}</td>
                    <td>{{ usuario.aplicaciones|length }}</td>
                    <td>{{ usuario.fechaCreacion|date('d/m/Y H:i:s') }}</td>
                    <td><span class="boton boton-warning btn__eliminar-usuario" data-usuario="{{ usuario.userIdentifier }}" data-accion="usuario-eliminar"><i class="bi bi-trash"></i></span></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}