{% extends 'base.html.twig' %}

{% trans_default_domain 'login' %}
{% block javascripts %}
    {{ importmap(['app', 'registro']) }}
{% endblock %}

{% block title %}{{ parent() }} | {{ 'Register'|trans }}{% endblock %}

{% block body %}
    <div class="contenido">
        <h2>Crea una nueva cuenta</h2>
    {{ form_start(registrationForm, {'attr': {'class': 'form'}}) }}
        <div class="form-enlinea">
            {{ form_label(registrationForm.usuario) }}
            {{ form_widget(registrationForm.usuario) }}
        </div>

        <div class="form-enlinea">
            {{ form_label(registrationForm.plainPassword) }}
            {{ form_widget(registrationForm.plainPassword) }}
        </div>
        {% if not registrationForm.plainPassword.vars.valid %}
            <div class="error">
                {{ registrationForm.plainPassword.vars.errors }}
            </div>
        {% endif %}

        <div class="form-enlinea">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email) }}
        </div>

        <button type="submit" class="boton boton-primary mt-2">{{ 'Create account'|trans }}</button>
        {{ form_end(registrationForm) }}
    </div>
{% endblock %}
